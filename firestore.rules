rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções Auxiliares ────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuth() && (
        request.auth.token[role] == true ||
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.roles[role] == true ||
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower().replace("@", "_").replace(".", "_") + "@rstopteam.internal")).data.roles[role] == true
      );
    }

    function isStaff() {
      return hasRole('admin') || hasRole('gestor') || hasRole('professor');
    }

    function hasPermission(key) {
      return isAuth() && (
        hasRole('admin') ||
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.permissions[key] == true ||
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower().replace("@", "_").replace(".", "_") + "@rstopteam.internal")).data.permissions[key] == true
      );
    }

    // ── Coleção de Usuários ──────────────────────────────────────────────────
    match /users/{userId} {
      allow get, list: if true;

      match /privacy/secrets {
        allow read: if isAuth() && (
          (request.auth.token.email.lower() == userId.lower()) ||
          hasRole('admin') ||
          hasRole('gestor') ||
          hasPermission('viewStaffPins')
        );
        allow write, delete: if isAuth() && (hasRole('admin') || hasRole('gestor'));
      }

      allow create, update, delete: if isAuth() && (
        hasRole('admin') || 
        hasRole('gestor') ||
        isStaff() ||
        hasPermission('manageUsers') ||
        (request.auth.token.email.lower() == userId.lower())
      );
    }

    // ── Modalidades e Turmas ──────────────────────────────────────────────────
    match /modalities/{modalityId} {
      allow read:  if isAuth(); 
      allow write: if isStaff(); 

      match /turmas/{turmaId} {
        allow read:  if isAuth();
        allow write: if isStaff();
      }
    }

    // ── Sessões e Presenças ───────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:  if isAuth();
      allow write: if isStaff() || isAuth();

      match /attendances/{attId} {
        allow read, write: if isAuth();
      }
    }

    match /attendance/{docId} {
      allow read:  if isAuth();
      allow write: if isStaff() || isAuth();
    }

    // ── Coleções Restritas ────────────────────────────────────────────────────
    match /finance/{docId}   { 
      allow read: if isStaff(); 
      allow write: if hasRole('admin') || hasRole('gestor'); 
    }
    match /billing/{docId}   { 
      allow read: if isStaff();
      allow write: if hasRole('admin') || hasRole('gestor'); 
    }
    match /expenses/{docId}   { 
      allow read: if isStaff();
      allow write: if hasRole('admin') || hasRole('gestor'); 
    }
    match /systemLogs/{docId} { allow write: if isAuth(); allow read: if isStaff(); }

    match /equipe/{uId} {
      allow read, write, delete: if isAuth() && (hasRole('admin') || hasRole('gestor'));
      match /privacy/secrets {
        allow read, write, delete: if isAuth() && (hasRole('admin') || hasRole('gestor') || request.auth.token.email.lower() == uId.lower());
      }
    }

    match /students/{uId} {
      allow read, write, delete: if isAuth() && (hasRole('admin') || hasRole('gestor'));
      match /privacy/secrets {
        allow read, write, delete: if isAuth() && (hasRole('admin') || hasRole('gestor') || request.auth.token.email.lower() == uId.lower());
      }
    }

    // ── Avisos e Notificações (Notices) ─────────────────────────────────────────
    match /notices/{noticeId} {
      allow get, list: if isAuth();
      allow create, update: if isStaff();
      allow delete: if hasRole('admin') || hasRole('gestor');
    }

    match /notice_views/{viewId} {
      allow read, write: if isAuth();
    }

    match /{document=**} {
      allow read, write, delete: if isAuth() && hasRole('admin');
    }
  }
}

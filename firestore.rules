rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções Auxiliares ────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole(email, role) {
      return get(/databases/$(database)/documents/users/$(email)).data.roles.get(role, false) == true ||
             get(/databases/$(database)/documents/users/$(email)).data.role == role;
    }

    function hasRole(role) {
      return isAuth() && (
        exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) &&
        getRole(request.auth.token.email.lower(), role)
      );
    }

    function isStaff() {
      return hasRole('admin') || hasRole('gestor') || hasRole('professor');
    }

    function hasPermission(key) {
      return isAuth() && (
        exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.permissions.get(key, false) == true
      );
    }

    // ── Coleção de Usuários ──────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if true;
      allow list: if isAuth();

      match /privacy/secrets {
        allow read: if isAuth() && (
          (request.auth.token.email.lower() == userId.lower()) ||
          hasRole('admin') ||
          hasRole('gestor') ||
          hasPermission('viewStaffPins')
        );
        allow write: if isAuth() && (hasRole('admin') || hasRole('gestor'));
      }

      allow create: if isAuth() && (
        hasRole('admin') || 
        hasRole('gestor') ||
        hasPermission('manageUsers') ||
        (request.auth.token.email.lower() == userId.lower())
      );
      
      allow update: if isAuth() && (
        hasRole('admin') || 
        hasRole('gestor') || 
        hasPermission('manageUsers') || 
        request.auth.token.email.lower() == userId.lower()
      );
      
      allow delete: if isAuth() && (hasRole('admin') || hasPermission('manageUsers'));
    }

    // ── Modalidades e Turmas ──────────────────────────────────────────────────
    match /modalities/{modalityId} {
      allow read:  if isAuth(); 
      allow write: if isStaff(); 

      match /turmas/{turmaId} {
        allow read:  if isAuth();
        allow write: if isStaff();
      }
    }

    // ── Sessões e Presenças ───────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:  if isAuth();
      allow write: if isStaff() || isAuth();

      match /attendances/{attId} {
        allow read, write: if isAuth();
      }
    }

    match /attendance/{docId} {
      allow read:  if isAuth();
      allow write: if isStaff() || isAuth();
    }

    // ── Coleções Restritas ────────────────────────────────────────────────────
    match /finance/{docId}   { allow read, write: if hasRole('admin') || hasRole('gestor'); }
    match /billing/{docId}   { allow read, write: if hasRole('admin') || hasRole('gestor'); }
    match /systemLogs/{docId} { allow write: if isAuth(); allow read: if isStaff(); }

    match /{document=**} {
      allow read, write: if isAuth() && hasRole('admin');
    }

    // ── Cofres Legados ───────────────────────────────────────────────────────
    match /equipe/{uId}/privacy/secrets {
      allow read: if isAuth() && (hasRole('admin') || hasRole('gestor') || request.auth.token.email.lower() == uId.lower());
    }
    match /students/{uId}/privacy/secrets {
      allow read: if isAuth() && (hasRole('admin') || hasRole('gestor') || request.auth.token.email.lower() == uId.lower());
    }
  }
}

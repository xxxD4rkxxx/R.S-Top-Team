rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções de Segurança ──────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }

    function isAdmin() {
      let email = request.auth.token.email.lower();
      return isAuth() && (
        email == 'pmadsonm@gmail.com' || 
        email == 'pmadsonm_gmail_com@rstopteam.internal' ||
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/usuarios/$(email)) && (
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('permissões', {}).get('all', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('permissions', {}).get('all', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('papeis', {}).get('admin', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('roles', {}).get('admin', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('role', '') == 'admin'
        ))
      );
    }

    function isStaff() {
      let email = request.auth.token.email.lower();
      return isAuth() && (
        isAdmin() ||
        request.auth.token.gestor == true ||
        request.auth.token.professor == true ||
        (exists(/databases/$(database)/documents/usuarios/$(email)) && (
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('permissões', {}).get('all', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('permissions', {}).get('all', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('papeis', {}).get('gestor', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('papeis', {}).get('professor', false) == true ||
          get(/databases/$(database)/documents/usuarios/$(email)).data.get('role', '') in ['gestor', 'professor']
        ))
      );
    }

// ── CRIAÇÃO DE PERFIL: Qualquer usuário autenticado pode criar seu próprio perfil
    // Staff pode criar outros perfis (necessário para gestão de equipe)
    match /usuarios/{userId} {
      allow create: if isAuth() && (request.auth.token.email.lower() == userId.lower() || isStaff());
      allow get: if true;
      allow list: if isAuth() || request.query.limit <= 1;

      match /privacy/secrets {
        allow read: if isAuth() && (isStaff() || request.auth.token.email.lower() == userId.lower());
        allow write: if isAuth() && isStaff();
      }
      
      match /anotacoes/{id} { allow read, write: if isStaff(); }
      match /graduacoes/{id} { allow read: if isAuth(); allow write: if isStaff(); }
      match /visitantes/{id} { allow read, write: if isStaff(); }

       // TODO: Validar no backend que o usuário só concede permissões que possui.
       // Firestore Rules tem limitações para comparação complexa de objetos.
       // A validação principal está no front-end (UserCreationModal.jsx - canGrantPermission + handleSubmit).
       allow update: if isAuth() && (isStaff() || request.auth.token.email.lower() == userId.lower())
                             && (
                                request.resource.data.get('telefone', '').size() == 0 || 
                                (request.resource.data.get('telefone', '').size() >= 10 && request.resource.data.get('telefone', '').size() <= 15)
                              );
      allow delete: if isAdmin();
    }

    // ── Suporte para Collection Group ─────────────────────────────────────────
    match /{path=**}/turmas/{tId} {
      allow read: if isAuth();
    }
    match /{path=**}/visualizacoes/{vId} {
      allow read, write: if isAuth();
    }
    match /{path=**}/presencas/{pId} {
      allow read: if isAuth();
    }

    // ── Perfil de Usuário (sub-coleções) ───────────────────────────────────────
    // ATENÇÃO: Evite criar match duplicados para /usuarios/{userId}

    // ── Modalidades e Turmas ──────────────────────────────────────────────────
    match /modalidades/{id} {
      allow read:  if isAuth(); 
      allow write: if isStaff(); 
      match /turmas/{tId} { allow read: if isAuth(); allow write: if isStaff(); }
    }

    // ── Operacional (Chamadas e Presenças) ────────────────────────────────────
    match /chamadas/{id} {
      allow read:  if isAuth();
      allow write: if isStaff(); 
      match /presencas/{pId} { allow read, write: if isAuth(); }
    }
    match /presencas_log/{id} { allow read, write: if isAuth(); }

    // ── Gestão Financeira ─────────────────────────────────────────────────────
    match /faturamento/{id} { 
      allow read: if isStaff() || (isAuth() && (resource.data.studentId == request.auth.uid || resource.data.studentId == request.auth.token.email.lower()));
      allow write: if isStaff(); 
    }
    
    // DESPESAS (Privado Staff)
    match /despesas/{id} { 
      allow read, write: if isStaff(); 
    }
    
    // CONTRATOS
    match /contratos/{id} { 
      allow read: if isStaff() || (isAuth() && (resource.data.studentId == request.auth.uid || resource.data.studentId == request.auth.token.email.lower()));
      allow write: if isStaff(); 
    }
    match /planos/{id}      { allow read, write: if isStaff(); }

    // ── Comunicação e Eventos ─────────────────────────────────────────────────
    match /eventos/{id} {
      allow read: if isAuth();
      allow write: if isStaff();
      // Permitir que qualquer usuário autenticado incremente o contador de visualizações
      allow update: if isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
    }

    // ── Visitantes e Leads ────────────────────────────────────────────────────
    match /visitantes/{id} {
      allow read: if isStaff();
      allow write: if (isStaff() || request.auth == null) 
                   && (
                     request.resource.data.get('telefone', '').size() == 0 ||
                     (request.resource.data.get('telefone', '').size() >= 10 && request.resource.data.get('telefone', '').size() <= 15)
                     );
      match /visitantes/{subId} { allow read, write: if isStaff(); }
    }

    // ── Configurações e Logs ──────────────────────────────────────────────────
    match /cofre_pins/{id} { allow read, write: if isStaff(); }
    match /configuracoes_jornada/{id} { allow read, write: if isStaff(); }
    match /logs_sistema/{id} { allow read: if isStaff(); allow write: if isAuth(); }

    // ── Compatibilidade Legada ────
    match /users/{id}    { allow read, write: if isStaff(); }
    match /alunos/{id}   { 
      allow read, write: if isStaff(); 
    }
    match /students/{id} { 
      allow read, write: if isStaff(); 
    }
  }
}

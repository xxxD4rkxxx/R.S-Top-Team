import { useState, useEffect, useRef } from 'react'
import { db } from '../firebase/config'
import { 
  collection, query, where, onSnapshot, 
  orderBy, getDocs, addDoc, doc, 
  updateDoc, deleteDoc, serverTimestamp 
} from 'firebase/firestore'
import { COLLECTIONS } from '../firebase/collections'
import { useAuth } from '../context/AuthContext'

/**
 * Hook para gerenciar as operações financeiras (Receitas e Despesas).
 * Sem cache global contaminante — cada userId+role tem subscription isolada.
 * Suporta offline via onSnapshot nativo do Firestore.
 */
// ── Subscription Channel Isolado por userId ───────────────────────────────────────────
const _channels = {} // key: `${userId}_${role}`, value: { unsub, subscribers, loading }

function subscribeToFinance(uid, role, type, callback) {
  const key = `${uid}_${role}_${type}`
  if (!_channels[key]) {
    _channels[key] = { unsub: null, subscribers: [], loading: true }
  }
  const channel = _channels[key]
  channel.subscribers.push(callback)

  if (!channel.unsub) {
    const ref = collection(db, type === 'cobrancas' ? COLLECTIONS. FATURAMENTO : COLLECTIONS. DESPESAS)
    let q;

    if (type === 'cobrancas') {
      q = role === 'aluno'
        ? query(ref, where('studentId', '==', uid), orderBy('dueDate', 'desc'))
        : query(ref, orderBy('dueDate', 'desc'))
    } else {
      q = query(ref, orderBy('dueDate', 'desc'))
    }

    channel. unsub = onSnapshot(q, (snap) => {
      const data = snap. docs.map(d => ({ id: d.id, ...d.data() }))
      channel.loading = false
      channel.subscribers.forEach(cb => cb(data, false))
    }, (err) => {
      console.error(`Erro no canal ${type}:`, err)
      channel.loading = false
      channel.subscribers.forEach(cb => cb([], false))
    })
  }

  // Retorna instantaneamente se já tem dados carregados
  if (!channel.loading && channel. _lastData) {
    callback(channel._lastData, false)
  }

  return () => {
    channel.subscribers = channel.subscribers.filter(cb => cb !== callback)
    if (channel.subscribers.length === 0 && channel.unsub) {
      channel.unsub()
      channel.unsub = null
      channel.loading = true
      channel._lastData = null
      delete _channels[key]
    }
  }
}

export function useFinance() {
  const { user, userData, effectiveRole } = useAuth()
  const userId = userData?.id || user?.uid

  const [cobrancas, setCobrancas] = useState([])
  const [carregandoCobrancas, setCarregandoCobrancas] = useState(true)
  const [despesas, setDespesas] = useState([])
  const [carregandoDespesas, setCarregandoDespesas] = useState(true)

  useEffect(() => {
    if (!user || !userId) {
      setCobrancas([])
      setDespesas([])
      setCarregandoCobrancas(false)
      setCarregandoDespesas(false)
      return
    }

    const unsubCob = subscribeToFinance(userId, effectiveRole, 'cobrancas', (data, loading) => {
      setCobrancas(data)
      setCarregandoCobrancas(loading)
    })

    let unsubDesp = () => {}
    if (effectiveRole !== 'aluno' && effectiveRole !== 'professor') {
      unsubDesp = subscribeToFinance(userId, effectiveRole, 'despesas', (data, loading) => {
        setDespesas(data)
        setCarregandoDespesas(loading)
      })
    } else {
      setDespesas([])
      setCarregandoDespesas(false)
    }

    return () => {
      unsubCob()
      unsubDesp()
    }
  }, [userId, effectiveRole])

  // ── KPIs ──
  const todayStr = new Date(). toISOString().split('T')[0]
  const cobrancasVencidas = cobrancas.filter(b =>
    b.status === 'overdue' || (b.status === 'pending' && b.dueDate < todayStr)
  )
  const cobrancasPendentes = cobrancas.filter(b => b.status === 'pending' && b.dueDate >= todayStr)
  const cobrancasPagas = cobrancas.filter(b => b.status === 'paid')
  const totalVencido = cobrancasVencidas.reduce((sum, b) => sum + (Number(b.amount) || 0), 0)
  const totalPendente = cobrancasPendentes.reduce((sum, b) => sum + (Number(b.amount) || 0), 0)
  const totalPago = cobrancasPagas.reduce((sum, b) => sum + (Number(b.amount) || 0), 0)

  // ── Despesas KPIs ──
  const despesasPagas = despesas.filter(d => d.status === 'paid')
  const despesasPendentes = despesas.filter(d => d.status === 'pending')
  const totalDespesasPagas = despesasPagas.reduce((sum, d) => sum + (Number(d.amount) || 0), 0)
  const totalDespesasPendentes = despesasPendentes.reduce((sum, d) => sum + (Number(d.amount) || 0), 0)

  // ── CRUD COBRANÇAS ──
  async function criarCobranca(dadosCobranca) {
    if (effectiveRole === 'aluno') throw new Error('Acesso Negado.')
    const ref = collection(db, COLLECTIONS. FATURAMENTO)
    await addDoc(ref, {
      ...dadosCobranca,
      createdAt: serverTimestamp(),
      amount: Number(dadosCobranca.amount)
    })
  }

  async function gerarCobrancasEmLote(alunos, modalidades, mesReferencia, dataVencimento) {
    if (effectiveRole === 'aluno' || effectiveRole === 'professor') throw new Error('Acesso Negado.')

    const normalizeText = (text) => {
      if (!text) return ''
      return text.toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    }

    const alunosAtivos = alunos.filter(a => a.roles?.aluno === true && a.status === 'Ativo')
    const cobrancasRef = collection(db, COLLECTIONS. FATURAMENTO)
    let criadas = 0

    for (const aluno of alunosAtivos) {
      if (aluno.isPaymentExempt) continue

      let valorFinal = 0
      const cat = (aluno.ageCategory || 'Adulto').toLowerCase()
      const modsAluno = Array.isArray(aluno.modalities) ? aluno.modalities : [aluno.modality].filter(Boolean)

      modsAluno.forEach(modName => {
        const normalizedSearch = normalizeText(modName)
        const modConfig = modalidades.find(m =>
          normalizeText(m.name) === normalizedSearch ||
          normalizeText(m.id) === normalizedSearch ||
          normalizeText(m.slug) === normalizedSearch
        )
        if (modConfig?.pricing?.[cat]?.enabled) {
          valorFinal += Number(modConfig.pricing[cat].price) || 0
        }
      })

      if (valorFinal > 0) {
        await addDoc(cobrancasRef, {
          studentId: aluno.id,
          studentName: aluno.name,
          amount: valorFinal,
          status: 'pending',
          dueDate: dataVencimento,
          referenceMonth: mesReferencia,
          createdAt: serverTimestamp()
        })
        criadas++
      }
    }
    return criadas
  }

  async function atualizarStatusCobranca(idCobranca, novoStatus) {
    if (effectiveRole === 'aluno') throw new Error('Acesso Negado.')
    const ref = doc(db, COLLECTIONS. FATURAMENTO, idCobranca)
    const payload = { status: novoStatus, updatedAt: serverTimestamp() }
    if (novoStatus === 'paid') payload.paidAt = serverTimestamp()
    else payload.paidAt = null
    await updateDoc(ref, payload)
  }

  async function atualizarCobranca(idCobranca, dados) {
    if (effectiveRole === 'aluno') throw new Error('Acesso Negado.')
    await updateDoc(doc(db, COLLECTIONS. FATURAMENTO, idCobranca), {
      ...dados,
      updatedAt: serverTimestamp()
    })
  }

  async function deletarCobranca(idCobranca) {
    if (effectiveRole === 'aluno') throw new Error('Acesso Negado.')
    await deleteDoc(doc(db, COLLECTIONS. FATURAMENTO, idCobranca))
  }

  async function recalcularCobrancasDoAluno(aluno, modalidades) {
    if (!aluno || effectiveRole === 'aluno' || effectiveRole === 'professor') {
      throw new Error('Acesso Negado.')
    }

    const normalizeText = (text) => {
      if (!text) return ''
      return text.toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    }

    const cat = (aluno.ageCategory || 'Adulto').toLowerCase()
    const modsAluno = Array.isArray(aluno.modalities) ? aluno.modalities : [aluno.modality].filter(Boolean)

    let novoValor = 0
    modsAluno.forEach(modName => {
      const normalizedSearch = normalizeText(modName)
      const modConfig = modalidades.find(m =>
        normalizeText(m.name) === normalizedSearch ||
        normalizeText(m.id) === normalizedSearch ||
        normalizeText(m.slug) === normalizedSearch
      )
      if (modConfig?.pricing?.[cat]?.enabled) {
        novoValor += Number(modConfig.pricing[cat].price) || 0
      }
    })

    if (novoValor <= 0) return 0

    const pendentes = cobrancas.filter(b => b.studentId === aluno.id && b.status === 'pending')
    let atualizadas = 0
    for (const cobranca of pendentes) {
      await updateDoc(doc(db, COLLECTIONS. FATURAMENTO, cobranca.id), {
        amount: novoValor,
        updatedAt: serverTimestamp(),
        autoUpdated: true
      })
      atualizadas++
    }
    return atualizadas
  }

  // ── CRUD DESPESAS ──
  async function criarDespesa(dadosDespesa) {
    if (effectiveRole !== 'gestor' && effectiveRole !== 'admin') throw new Error('Acesso Negado.')
    await addDoc(collection(db, COLLECTIONS. DESPESAS), {
      ...dadosDespesa,
      createdAt: serverTimestamp(),
      amount: Number(dadosDespesa.amount)
    })
  }

  async function atualizarDespesa(idDespesa, dados) {
    if (effectiveRole !== 'gestor' && effectiveRole !== 'admin') throw new Error('Acesso Negado.')
    await updateDoc(doc(db, COLLECTIONS. DESPESAS, idDespesa), {
      ...dados,
      updatedAt: serverTimestamp()
    })
  }

  async function deletarDespesa(idDespesa) {
    if (effectiveRole !== 'gestor' && effectiveRole !== 'admin') throw new Error('Acesso Negado.')
    await deleteDoc(doc(db, COLLECTIONS. DESPESAS, idDespesa))
  }

  return {
    bills: cobrancas,
    loading: carregandoCobrancas,
    overdueBills: cobrancasVencidas,
    overdueCount: cobrancasVencidas.length,
    pendingCount: cobrancasPendentes.length,
    totalOverdue: totalVencido,
    totalPending: totalPendente,
    totalPaid: totalPago,
    addBill: criarCobranca,
    updateBill: atualizarCobranca,
    gerarCobrancasEmLote,
    generateBatchBilling: gerarCobrancasEmLote,
    updateBillStatus: atualizarStatusCobranca,
    deleteBill: deletarCobranca,
    recalculatePendingBills: recalcularCobrancasDoAluno,
    expenses: despesas,
    loadingExpenses: carregandoDespesas,
    expensesPaidTotal: totalDespesasPagas,
    expensesPendingTotal: totalDespesasPendentes,
    addExpense: criarDespesa,
    updateExpense: atualizarDespesa,
    deleteExpense: deletarDespesa
  }
}